{
  "name": "emerald",
  "version": "1.0.3",
  "description": "> A lightweight, self-hosted markdown editor with live preview, folder organisation, image support, and full theme customisation. No accounts. No cloud. Your notes stay on your device.",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "dist:release": "electron-builder -p always"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/barral0/emerald.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/barral0/emerald/issues"
  },
  "homepage": "https://github.com/barral0/emerald#readme",
  "devDependencies": {
    "dotenv": "^17.3.1",
    "electron": "^40.6.1",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.github.barral0.emerald",
    "productName": "Emerald",
    "publish": [
      {
        "provider": "github",
        "owner": "barral0",
        "repo": "emerald"
      }
    ],
    "directories": {
      "output": "dist"
    },
    "icon": "assets/icons/icon.png",
    "win": {
      "target": "nsis",
      "artifactName": "Emerald-Setup-${version}.${ext}"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    }
  },
  "dependencies": {
    "electron-updater": "^6.8.3",
    "sharp": "^0.34.5"
  }
}